enable
configure terminal
!
hostname DC
!
ip domain-name cisco.com
crypto key generate rsa modulus 1024
ip ssh version 2
username cisco secret Cisco
enable secret Cisco
!
line vty 0 4
transport input ssh
login local
!
interface f0/0
ip address 192.168.2.1 255.255.255.0
no shutdown
!
interface g1/0
ip address 10.2.2.1 255.255.255.0
no shutdown
!
!Enrutamiento estatico
ip route 192.168.1.0 255.255.255.0 10.2.2.2
!
interface g2/0
ip address 10.4.4.2 255.255.255.0
no shutdown
!
ip route 192.168.1.0 255.255.255.0 10.4.4.1 
!
ip sla 1
icmp-echo 10.0.0.1 source-interface g1/0
frequency 5
exit
ip sla schedule 1 start now life forever
!
ip route 10.0.0.0 255.255.255.0 10.2.2.2
!
track 1 ip sla 1 state
exit
ip route 192.168.1.0 255.255.255.0 10.2.2.2 track 1
ip route 192.168.1.0 255.255.255.0 10.4.4.1  10
no ip route 192.168.1.0 255.255.255.0 10.4.4.1
