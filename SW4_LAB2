enable
configure terminal
!
hostname SW4
!
vlan 10,20
vlan 99
name native
vlan 25
name management
!
interface vlan 25
no shutdown
ip address 192.168.25.14 255.255.255.0
!
ip default-gateway 192.168.25.1
!
spanning-tree mode rapid
!
interface range g0/1-3
switchport mode access
switchport access vlan 20
spanning-tree portfast
spanning-tree bpduguard enable
!
interface range g0/0,g1/1-2
switchport trunk encapsulation dot1q
switchport mode trunk
switchport trunk native vlan 99
switchport trunk allow vlan 1,10,20,25,99
switchport nonegotiate
!
ip domain-name cisco.com
crypto key generate rsa modulus 1024
ip ssh version 2
username cisco secret Cisco
enable secret Cisco
!
line vty 0 4
transport input ssh
login local
!
##Port Channel
default interface g1/3
interface g1/3
shutdown
interface g1/3
channel-group 2 mode active
!
interface port-channel 2
switchport trunk encapsulation dot1q
switchport mode trunk
switchport trunk native vlan 99
switchport trunk allow vlan 1,10,20,25,99
switchport nonegotiate


default interface g1/1
interface g1/1
shutdown
interface g1/1
channel-group 2 mode active
!
interface port-channel 2
switchport trunk encapsulation dot1q
switchport mode trunk
switchport trunk native vlan 99
switchport trunk allow vlan 1,10,20,25,99
switchport nonegotiate
